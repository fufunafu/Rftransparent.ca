<div class="container">
  <div class="cart-page">
    <div class="page-hero" style="padding-top:calc(var(--header-height) + 2rem);border-bottom:none;margin-bottom:0;">
      <h1 class="page-hero__title">Your Cart</h1>
    </div>

    {%- if cart.item_count == 0 -%}
      <div style="text-align:center;padding:5rem 1rem;">
        <svg width="64" height="64" fill="none" stroke="var(--color-border)" stroke-width="1" viewBox="0 0 24 24" style="margin-inline:auto;margin-bottom:1.5rem;">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <h2 style="margin-bottom:0.75rem;">Your cart is empty</h2>
        <p style="color:var(--color-text-muted);margin-bottom:2rem;">Looks like you haven't added anything yet.</p>
        <a href="/collections/all-products" class="btn btn--primary">Browse Products</a>
      </div>
    {%- else -%}
      <div class="cart-page__grid">
        <!-- Line items -->
        <div>
          <form class="cart-page-form" action="/cart" method="post">
            <div class="cart-page__items">
              {%- for item in cart.items -%}
                <div class="cart-line" data-key="{{ item.key }}">
                  <!-- Image -->
                  <a href="{{ item.url }}" class="cart-line__image" aria-label="{{ item.title }}">
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.image.alt | default: item.title }}"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  </a>

                  <!-- Info -->
                  <div>
                    <a href="{{ item.url }}" class="cart-line__title">{{ item.product_title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="cart-line__variant">{{ item.variant.title }}</p>
                    {%- endunless -%}

                    <!-- Qty -->
                    <div class="qty-selector" style="margin-bottom:0.75rem;">
                      <button type="button" class="qty-selector__btn cart-line__qty-btn" data-key="{{ item.key }}" data-action="decrease" aria-label="Decrease quantity">−</button>
                      <input
                        type="number"
                        class="qty-selector__input"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="1"
                        aria-label="Quantity for {{ item.title }}"
                      >
                      <button type="button" class="qty-selector__btn cart-line__qty-btn" data-key="{{ item.key }}" data-action="increase" aria-label="Increase quantity">+</button>
                    </div>

                    <a href="/cart/change?id={{ item.key }}&quantity=0" class="cart-line__remove">Remove</a>
                  </div>

                  <!-- Price -->
                  <div class="cart-line__price">{{ item.final_line_price | money }}</div>
                </div>
              {%- endfor -%}
            </div>

            <!-- Coupon note -->
            <div class="form-group" style="margin-top:1.5rem;max-width:400px;">
              <label class="form-label" for="cart-note">Order notes (optional)</label>
              <textarea id="cart-note" name="note" class="form-textarea" rows="2" placeholder="Special instructions for your order…">{{ cart.note }}</textarea>
            </div>
          </form>
        </div>

        <!-- Summary -->
        <div class="cart-summary">
          <h2 class="cart-summary__title">Order Summary</h2>

          <div class="cart-summary__row">
            <span class="cart-summary__label">Subtotal ({{ cart.item_count }} items)</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <div class="cart-summary__row">
            <span class="cart-summary__label">Shipping</span>
            <span>Calculated at checkout</span>
          </div>
          <div class="cart-summary__row cart-summary__row--total">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="cart-summary__checkout">
            <a href="/checkout" class="btn btn--primary btn--full btn--lg">
              Proceed to Checkout
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
            <a href="/collections/all-products" class="btn btn--secondary btn--full">Continue Shopping</a>
          </div>

          <p class="cart-summary__secure">
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
            Secure SSL checkout
          </p>

          <!-- Payment icons -->
          <div style="display:flex;align-items:center;justify-content:center;gap:0.5rem;margin-top:1rem;opacity:0.5;">
            {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'payment-icon', style: 'height:24px;' }}
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": []
}
{% endschema %}
