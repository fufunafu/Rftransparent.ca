<div class="page-hero">
  <div class="container">
    <h1 class="page-hero__title">Log In</h1>
  </div>
</div>

<div class="container">
  <div class="auth-card">
    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div class="auth-errors" role="alert">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="form-field">
        <label for="customer-email">Email</label>
        <input
          type="email"
          id="customer-email"
          name="customer[email]"
          autocomplete="email"
          required
          class="form-input"
        >
      </div>

      <div class="form-field">
        <label for="customer-password">Password</label>
        <input
          type="password"
          id="customer-password"
          name="customer[password]"
          autocomplete="current-password"
          required
          class="form-input"
        >
      </div>

      <button type="submit" class="btn btn--primary auth-submit">Sign In</button>

      <div class="auth-links">
        <a href="#recover" id="recover-link" class="auth-link">Forgot your password?</a>
        <a href="/account/register" class="auth-link">Create account</a>
      </div>
    {%- endform -%}

    <!-- Password recovery form -->
    <div id="recover-form" class="recover-form" style="display:none;">
      <h2 class="recover-form__title">Reset Your Password</h2>
      <p class="recover-form__text">We will send you an email to reset your password.</p>

      {%- form 'recover_customer_password' -%}
        {%- if form.posted_successfully? -%}
          <p class="auth-success">We've sent you an email with a link to update your password.</p>
        {%- endif -%}

        <div class="form-field">
          <label for="recover-email">Email</label>
          <input
            type="email"
            id="recover-email"
            name="email"
            autocomplete="email"
            required
            class="form-input"
          >
        </div>

        <button type="submit" class="btn btn--primary auth-submit">Submit</button>
        <a href="#" id="cancel-recover" class="auth-link" style="display:block;text-align:center;margin-top:1rem;">Cancel</a>
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .auth-card {
    max-width: 440px;
    margin: 2rem auto 4rem;
    padding: 2.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
  .auth-errors {
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .auth-success {
    background: #f0fdf4;
    border: 1px solid #86efac;
    color: #166534;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .form-field { margin-bottom: 1.25rem; }
  .form-field label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-bottom: 0.35rem;
  }
  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-bg);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .form-input:focus { border-color: var(--color-accent); }
  .auth-submit { width: 100%; margin-top: 0.5rem; }
  .auth-links {
    display: flex;
    justify-content: space-between;
    margin-top: 1.25rem;
  }
  .auth-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
  }
  .auth-link:hover { text-decoration: underline; }
  .recover-form__title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .recover-form__text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
</style>

<script>
  (function() {
    var recoverLink = document.getElementById('recover-link');
    var cancelRecover = document.getElementById('cancel-recover');
    var recoverForm = document.getElementById('recover-form');
    var loginForm = recoverForm ? recoverForm.previousElementSibling : null;

    if (recoverLink && recoverForm) {
      recoverLink.addEventListener('click', function(e) {
        e.preventDefault();
        if (loginForm) loginForm.style.display = 'none';
        recoverForm.style.display = 'block';
      });
    }
    if (cancelRecover && recoverForm) {
      cancelRecover.addEventListener('click', function(e) {
        e.preventDefault();
        recoverForm.style.display = 'none';
        if (loginForm) loginForm.style.display = 'block';
      });
    }
    if (window.location.hash === '#recover' && recoverLink) {
      recoverLink.click();
    }
  })();
</script>

{% schema %}
{
  "name": "Login",
  "settings": []
}
{% endschema %}
