<section class="newsletter section">
  <div class="container">
    <div class="newsletter__inner">
      <div class="newsletter__content reveal">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2>{{ section.settings.heading | default: "Stay in the Loop" }}</h2>
        {%- if section.settings.text != blank -%}
          <p class="newsletter__text">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
      <div class="newsletter__form reveal reveal--delay-1">
        {%- form 'customer', id: 'newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter__input-group">
            <label for="newsletter-email" class="sr-only">Email address</label>
            <input
              type="email"
              name="contact[email]"
              id="newsletter-email"
              class="form-input newsletter__input"
              placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
              required
              autocomplete="email"
              aria-label="Email address"
            >
            <button type="submit" class="btn btn--accent newsletter__btn">
              {{ section.settings.button_label | default: "Subscribe" }}
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="newsletter__success" role="status">{{ section.settings.success_message | default: "Thanks for subscribing!" }}</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="newsletter__error" role="alert">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
          {%- endif -%}
        {%- endform -%}
        {%- if section.settings.disclaimer != blank -%}
          <p class="newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Newsletter" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay in the Loop" },
    { "type": "textarea", "id": "text", "label": "Description", "default": "Get the latest product updates, installation tips, and exclusive offers delivered to your inbox." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for subscribing!" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer text", "default": "No spam, ever. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
