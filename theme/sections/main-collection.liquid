{%- paginate collection.products by section.settings.products_per_page -%}

<!-- Collection Hero -->
{%- if collection.image or section.settings.show_hero_bg -%}
  <div class="collection-hero collection-hero--with-bg">
    <div class="collection-hero__bg">
      {%- if collection.image -%}
        <img
          src="{{ collection.image | image_url: width: 1600 }}"
          alt="{{ collection.title }}"
          loading="eager"
          width="1600"
          height="600"
        >
      {%- endif -%}
    </div>
    <div class="collection-hero--with-bg .collection-hero__inner">
      <div style="max-width:var(--container-max);width:100%;margin-inline:auto;padding:3rem var(--container-pad);position:relative;z-index:1;">
        {%- render 'breadcrumb' -%}
        <h1 class="collection-hero__title">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <p class="collection-hero__desc">{{ collection.description | strip_html | truncate: 200 }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- else -%}
  <div class="collection-hero">
    {%- render 'breadcrumb' -%}
    <h1 class="collection-hero__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="collection-hero__desc">{{ collection.description | strip_html }}</p>
    {%- endif -%}
  </div>
{%- endif -%}

<!-- Main collection content -->
<div class="container">
  <!-- Toolbar -->
  <div class="collection-toolbar">
    <p class="collection-toolbar__count">
      {%- if collection.products_count == 1 -%}
        {{ collection.products_count }} product
      {%- else -%}
        {{ collection.products_count }} products
      {%- endif -%}
    </p>

    <div class="collection-toolbar__right">
      <label for="sort-by" class="collection-toolbar__sort-label">Sort by</label>
      <select id="sort-by" class="sort-select" aria-label="Sort products">
        {%- for option in collection.sort_options -%}
          <option value="{{ option.value }}"{% if option.value == collection.sort_by %} selected{% endif %}>
            {{ option.name }}
          </option>
        {%- endfor -%}
      </select>
    </div>
  </div>

  <!-- Product grid -->
  <div class="collection-page">
    {%- if collection.products.size == 0 -%}
      <div style="text-align:center;padding:5rem 1rem;">
        <h2 style="margin-bottom:1rem;">No products found</h2>
        <p style="color:var(--color-text-muted);margin-bottom:2rem;">Try browsing our other collections.</p>
        <a href="/collections/all-products" class="btn btn--primary">Shop All Products</a>
      </div>
    {%- else -%}
      <div class="collection-grid">
        {%- for product in collection.products -%}
          {%- render 'product-card', product: product, index: forloop.index -%}
        {%- endfor -%}
      </div>

      <!-- Pagination -->
      {%- if paginate.pages > 1 -%}
        <nav class="collection-pagination" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="pagination-link" aria-label="Previous page">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="15 18 9 12 15 6"/>
              </svg>
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="pagination-link">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="pagination-link is-active" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="pagination-link" style="cursor:default;opacity:0.4;">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="pagination-link" aria-label="Next page">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="9 18 15 12 9 6"/>
              </svg>
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    { "type": "checkbox", "id": "show_hero_bg", "label": "Show hero with background color if no image", "default": false },
    { "type": "range", "id": "products_per_page", "min": 8, "max": 48, "step": 4, "label": "Products per page", "default": 24 }
  ]
}
{% endschema %}
