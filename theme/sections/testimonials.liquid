<section class="testimonials section">
  <div class="container">
    <div class="testimonials__header">
      <p class="eyebrow reveal">{{ section.settings.eyebrow | default: "Reviews" }}</p>
      <h2 class="reveal reveal--delay-1">{{ section.settings.heading | default: "What Our Customers Say" }}</h2>
    </div>

    <div class="testimonials-grid">
      {%- for block in section.blocks -%}
        <article class="testimonial-card reveal reveal--delay-{{ forloop.index }}">
          <div class="testimonial-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            {%- endfor -%}
          </div>
          <blockquote class="testimonial-card__text">"{{ block.settings.text }}"</blockquote>
          <footer class="testimonial-card__author">
            <div class="testimonial-card__avatar" aria-hidden="true">{{ block.settings.name | slice: 0 }}</div>
            <div>
              <div class="testimonial-card__name">{{ block.settings.name }}</div>
              {%- if block.settings.location != blank -%}
                <div class="testimonial-card__location">{{ block.settings.location }}</div>
              {%- endif -%}
            </div>
          </footer>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Reviews" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 6,
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Rating", "default": 5 },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Outstanding quality and service. The glass railings look absolutely beautiful and the installation was seamless thanks to their dealer network." },
        { "type": "text", "id": "name", "label": "Reviewer name", "default": "Michael T." },
        { "type": "text", "id": "location", "label": "Location (optional)", "default": "Toronto, ON" }
      ]
    }
  ],
  "presets": [{
    "name": "Testimonials",
    "blocks": [
      { "type": "review", "settings": { "name": "Michael T.", "location": "Toronto, ON", "text": "Outstanding quality and service. The glass railings look absolutely beautiful and the installation was seamless thanks to their dealer network." } },
      { "type": "review", "settings": { "name": "Sarah L.", "location": "Vancouver, BC", "text": "RF Transparent made the entire process easy. The quote was fast, the product is premium, and our deck looks incredible. Highly recommend." } },
      { "type": "review", "settings": { "name": "David R.", "location": "Calgary, AB", "text": "Best glass railing supplier in Canada. Used them on three commercial projects and every time the quality and lead times have been excellent." } }
    ]
  }]
}
{% endschema %}
