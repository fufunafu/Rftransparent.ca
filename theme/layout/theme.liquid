<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#1C3330">

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- render 'seo-meta' -%}

    {{ content_for_header }}

    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">

    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>

  <body class="template-{{ template.name }}{% if template.suffix %}-{{ template.suffix }}{% endif %}">
    <a class="skip-link" href="#MainContent">Skip to content</a>

    {%- section 'announcement-bar' -%}
    {%- section 'header' -%}

    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {%- section 'footer' -%}

    <div id="cart-drawer" class="cart-drawer" aria-hidden="true" role="dialog" aria-label="Shopping cart" aria-modal="true">
      {%- section 'cart-drawer' -%}
    </div>
    <div id="cart-overlay" class="cart-overlay" aria-hidden="true"></div>

    <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
      <nav class="mobile-nav__inner">
        <ul class="mobile-nav__links">
          {%- for link in linklists.main-menu.links -%}
            <li>
              <a href="{{ link.url }}" class="mobile-nav__link">{{ link.title }}</a>
              {%- if link.links.size > 0 -%}
                <ul class="mobile-nav__sub-links">
                  {%- for child in link.links -%}
                    <li><a href="{{ child.url }}" class="mobile-nav__sub-link">{{ child.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
        <div class="mobile-nav__actions">
          <a href="/pages/contact" class="btn btn--primary btn--full">Get a Quote</a>
          <a href="/pages/store-locator" class="btn btn--secondary btn--full" style="margin-top:0.75rem;">Find a Dealer</a>
        </div>
      </nav>
    </div>

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </body>
</html>
