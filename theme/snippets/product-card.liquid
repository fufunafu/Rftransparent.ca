{% comment %}
  Product Card Snippet
  Usage: {% render 'product-card', product: product, index: forloop.index %}
{% endcomment %}

{%- assign card_product = product -%}
{%- assign first_variant = card_product.selected_or_first_available_variant -%}

<article class="product-card reveal{% if index %} reveal--delay-{{ index | modulo: 4 | plus: 1 }}{% endif %}">
  <!-- Media -->
  <a href="{{ card_product.url }}" class="product-card__media" tabindex="-1" aria-hidden="true">
    {%- if card_product.featured_image -%}
      <img
        class="product-card__image"
        src="{{ card_product.featured_image | image_url: width: 600 }}"
        srcset="{{ card_product.featured_image | image_url: width: 400 }} 400w, {{ card_product.featured_image | image_url: width: 600 }} 600w"
        sizes="(max-width:480px) 100vw, (max-width:900px) 50vw, (max-width:1200px) 33vw, 25vw"
        alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
        loading="lazy"
        width="600"
        height="600"
      >
    {%- else -%}
      <div style="width:100%;height:100%;background:var(--color-bg-alt);display:flex;align-items:center;justify-content:center;">
        <svg width="48" height="48" fill="none" stroke="var(--color-border)" stroke-width="1" viewBox="0 0 24 24">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </div>
    {%- endif -%}

    {%- assign new_threshold = 'now' | date: '%s' | minus: 2592000 -%}
    {%- assign product_created_ts = card_product.created_at | date: '%s' | plus: 0 -%}
    {%- if card_product.compare_at_price > card_product.price -%}
      <span class="product-card__badge product-card__badge--sale">Sale</span>
    {%- elsif card_product.available == false -%}
      <span class="product-card__badge">Sold Out</span>
    {%- elsif product_created_ts > new_threshold -%}
      <span class="product-card__badge">New</span>
    {%- endif -%}

    {%- if first_variant.available -%}
      <button
        class="product-card__quick-add"
        data-variant-id="{{ first_variant.id }}"
        aria-label="Quick add {{ card_product.title }} to cart"
      >
        + Quick Add
      </button>
    {%- endif -%}
  </a>

  <!-- Info -->
  <a href="{{ card_product.url }}" class="product-card__info">
    {%- if card_product.collections.size > 0 -%}
      <span class="product-card__collection">{{ card_product.collections.first.title }}</span>
    {%- endif -%}

    <h3 class="product-card__title">{{ card_product.title }}</h3>

    <!-- Judge.me preview stars -->
    <div class="jdgm-widget jdgm-preview-badge" data-id="{{ card_product.id }}" style="font-size:12px;"></div>

    <div class="product-card__price-row">
      <span class="product-card__price">
        {%- if card_product.price_varies -%}
          From {{ card_product.price_min | money }}
        {%- else -%}
          {{ card_product.price | money }}
        {%- endif -%}
      </span>
      {%- if card_product.compare_at_price > card_product.price -%}
        <span class="product-card__price--compare">{{ card_product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </a>
</article>
