<section class="trust-badges section">
  <div class="container">
    <div class="trust-badges__grid">
      {%- for block in section.blocks -%}
        <div class="trust-badge reveal reveal--delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon">
            {%- case block.settings.icon -%}
              {%- when 'shield' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- when 'truck' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'award' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
              {%- when 'clock' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {%- when 'star' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'lock' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              {%- when 'map-pin' -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {%- else -%}
                <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {%- endcase -%}
          </div>
          <div class="trust-badge__text">
            <strong>{{ block.settings.title }}</strong>
            {%- if block.settings.description != blank -%}
              <span>{{ block.settings.description }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "shield", "options": [
          { "value": "shield", "label": "Shield" },
          { "value": "truck", "label": "Truck" },
          { "value": "award", "label": "Award" },
          { "value": "clock", "label": "Clock" },
          { "value": "star", "label": "Star" },
          { "value": "lock", "label": "Lock" },
          { "value": "map-pin", "label": "Map Pin" },
          { "value": "check", "label": "Checkmark" }
        ]},
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "description", "label": "Description", "default": "On orders over $500" }
      ]
    }
  ],
  "presets": [{
    "name": "Trust Badges",
    "blocks": [
      { "type": "badge", "settings": { "icon": "truck", "title": "Free Shipping", "description": "On orders over $500 CAD" } },
      { "type": "badge", "settings": { "icon": "shield", "title": "Lifetime Warranty", "description": "On all glass panels" } },
      { "type": "badge", "settings": { "icon": "award", "title": "10-Year Rust Warranty", "description": "On all hardware" } },
      { "type": "badge", "settings": { "icon": "map-pin", "title": "101+ Dealers", "description": "Across Canada" } },
      { "type": "badge", "settings": { "icon": "lock", "title": "Secure Checkout", "description": "SSL encrypted" } }
    ]
  }]
}
{% endschema %}
