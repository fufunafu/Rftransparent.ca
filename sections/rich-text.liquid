<section class="rich-text section{% if section.settings.centered %} rich-text--centered{% endif %}{% if section.settings.bg_dark %} section--dark{% elsif section.settings.bg_alt %} section--alt{% endif %}">
  <div class="container">
    <div class="rich-text__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow{% if section.settings.bg_dark %} eyebrow--light{% endif %} reveal">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="rich-text__heading reveal reveal--delay-1">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="rich-text__text reveal reveal--delay-2">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <div class="reveal reveal--delay-3" style="margin-top:2rem;">
          <a href="{{ section.settings.cta_url }}" class="btn{% if section.settings.bg_dark %} btn--outline-white{% else %} btn--primary{% endif %}">
            {{ section.settings.cta_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "settings": [
    { "type": "checkbox", "id": "centered", "label": "Center align", "default": true },
    { "type": "checkbox", "id": "bg_alt", "label": "Alternate background", "default": false },
    { "type": "checkbox", "id": "bg_dark", "label": "Dark background", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "cta_label", "label": "Button label" },
    { "type": "url", "id": "cta_url", "label": "Button link" }
  ],
  "presets": [{ "name": "Rich Text" }]
}
{% endschema %}
