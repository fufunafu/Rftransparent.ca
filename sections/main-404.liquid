<div class="error-page">
  <div class="error-page__inner">
    <p class="error-page__num" aria-hidden="true">404</p>
    <h1 class="error-page__title">Page Not Found</h1>
    <p class="error-page__text">The page you're looking for doesn't exist or may have been moved.</p>
    <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;">
      <a href="/" class="btn btn--primary">Back to Home</a>
      <a href="/collections/all-products" class="btn btn--secondary">Browse Products</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "404 Page",
  "settings": []
}
{% endschema %}
