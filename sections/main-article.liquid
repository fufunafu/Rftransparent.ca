<article class="article-page">
  <div class="container">
    {%- render 'breadcrumb' -%}

    <header class="article-header">
      <h1 class="article-header__title">{{ article.title }}</h1>
      <div class="article-header__meta">
        {%- if article.author -%}
          <span class="article-header__author">By {{ article.author }}</span>
        {%- endif -%}
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%B %d, %Y' }}
        </time>
      </div>
    </header>

    {%- if article.image -%}
      <div class="article-featured-image">
        <img
          src="{{ article.image | image_url: width: 1400 }}"
          srcset="{{ article.image | image_url: width: 700 }} 700w, {{ article.image | image_url: width: 1400 }} 1400w"
          sizes="(max-width:768px) 100vw, 900px"
          alt="{{ article.image.alt | default: article.title | escape }}"
          loading="eager"
          width="1400"
          height="700"
        >
      </div>
    {%- endif -%}

    <div class="article-content rte">
      {{ article.content }}
    </div>

    <!-- Social share -->
    <div class="article-share">
      <span class="article-share__label">Share:</span>
      <a
        href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: article.url | url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Share on Facebook"
        class="article-share__link"
      >Facebook</a>
      <a
        href="https://twitter.com/intent/tweet?url={{ shop.url | append: article.url | url_encode }}&text={{ article.title | url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Share on Twitter"
        class="article-share__link"
      >Twitter</a>
      <a
        href="https://www.linkedin.com/sharing/share-offsite/?url={{ shop.url | append: article.url | url_encode }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Share on LinkedIn"
        class="article-share__link"
      >LinkedIn</a>
    </div>

    <!-- Previous / Next navigation -->
    {%- if blog.previous_article or blog.next_article -%}
      <nav class="article-nav" aria-label="Article navigation">
        {%- if blog.previous_article -%}
          <a href="{{ blog.previous_article.url }}" class="article-nav__link article-nav__link--prev">
            <span class="article-nav__dir">&larr; Previous</span>
            <span class="article-nav__title">{{ blog.previous_article.title }}</span>
          </a>
        {%- else -%}
          <span></span>
        {%- endif -%}
        {%- if blog.next_article -%}
          <a href="{{ blog.next_article.url }}" class="article-nav__link article-nav__link--next">
            <span class="article-nav__dir">Next &rarr;</span>
            <span class="article-nav__title">{{ blog.next_article.title }}</span>
          </a>
        {%- endif -%}
      </nav>
    {%- endif -%}

    <!-- Judge.me comments -->
    <div class="article-comments">
      <div class="jdgm-widget jdgm-review-widget" data-id="{{ article.id }}"></div>
    </div>
  </div>
</article>

<style>
  .article-page { padding-bottom: 4rem; }
  .article-header { text-align: center; padding: 2rem 0 1.5rem; max-width: 800px; margin: 0 auto; }
  .article-header__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: var(--color-dark);
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }
  .article-header__meta {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  .article-featured-image {
    margin: 0 auto 2.5rem;
    max-width: 900px;
    border-radius: 8px;
    overflow: hidden;
  }
  .article-featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }
  .article-content {
    max-width: 750px;
    margin: 0 auto;
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }
  .article-content h2, .article-content h3 {
    font-family: var(--font-heading);
    color: var(--color-dark);
    margin: 2rem 0 0.75rem;
  }
  .article-content img {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    margin: 1.5rem 0;
  }
  .article-share {
    max-width: 750px;
    margin: 3rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .article-share__label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .article-share__link {
    font-size: 0.85rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .article-share__link:hover { text-decoration: underline; }
  .article-nav {
    max-width: 750px;
    margin: 2.5rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }
  .article-nav__link {
    text-decoration: none;
    color: var(--color-dark);
    max-width: 45%;
  }
  .article-nav__link--next { text-align: right; margin-left: auto; }
  .article-nav__dir {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }
  .article-nav__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    line-height: 1.3;
  }
  .article-nav__link:hover .article-nav__title { color: var(--color-accent); }
  .article-comments {
    max-width: 750px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
</style>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
