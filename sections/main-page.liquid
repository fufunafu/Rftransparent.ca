<div class="page-hero">
  {%- if page.title != blank -%}
    <p class="eyebrow page-hero__eyebrow">{{ page.title }}</p>
  {%- endif -%}
  <h1 class="page-hero__title">{{ page.title }}</h1>
</div>

<div class="container" style="padding-bottom:5rem;">
  <div class="page-content">
    {{ page.content }}
  </div>
</div>

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
