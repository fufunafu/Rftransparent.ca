<section class="featured-products section section--alt">
  <div class="container">
    <div class="section-header">
      <div class="section-header__left">
        <p class="eyebrow reveal">{{ section.settings.eyebrow | default: "Bestsellers" }}</p>
        <h2 class="reveal reveal--delay-1">{{ section.settings.heading | default: "Our Most Popular Products" }}</h2>
      </div>
      <a href="/collections/all-products" class="btn btn--secondary reveal reveal--delay-2">Shop All</a>
    </div>

    <div class="products-grid">
      {%- for block in section.blocks -%}
        {%- if block.settings.product != blank -%}
          {%- assign prod = all_products[block.settings.product] -%}
          {%- render 'product-card', product: prod, index: forloop.index -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bestsellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Most Popular Products" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 8,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [{
    "name": "Featured Products",
    "blocks": [
      { "type": "product" },
      { "type": "product" },
      { "type": "product" },
      { "type": "product" }
    ]
  }]
}
{% endschema %}
