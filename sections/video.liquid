<section class="video-section section">
  <div class="container">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="video-section__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow reveal">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="reveal reveal--delay-1">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="video-section__text reveal reveal--delay-2">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="video-section__player reveal">
      {%- if section.settings.video_url != blank -%}
        {%- assign video_url = section.settings.video_url -%}
        {%- if video_url contains 'youtube.com' or video_url contains 'youtu.be' -%}
          {%- if video_url contains 'youtu.be/' -%}
            {%- assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first -%}
          {%- else -%}
            {%- assign video_id = video_url | split: 'v=' | last | split: '&' | first -%}
          {%- endif -%}
          <div class="video-section__wrapper" data-video-id="{{ video_id }}" data-video-type="youtube">
            {%- if section.settings.cover_image != blank -%}
              <img
                src="{{ section.settings.cover_image | image_url: width: 1200 }}"
                alt="{{ section.settings.heading | default: 'Video' | escape }}"
                class="video-section__cover"
                loading="lazy"
                width="1200"
                height="675"
              >
            {%- else -%}
              <img
                src="https://img.youtube.com/vi/{{ video_id }}/maxresdefault.jpg"
                alt="{{ section.settings.heading | default: 'Video' | escape }}"
                class="video-section__cover"
                loading="lazy"
                width="1200"
                height="675"
              >
            {%- endif -%}
            <button class="video-section__play" aria-label="Play video">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="white" stroke-width="2" fill="rgba(0,0,0,0.4)"/>
                <polygon points="26,20 26,44 46,32" fill="white"/>
              </svg>
            </button>
          </div>
        {%- elsif video_url contains 'vimeo.com' -%}
          {%- assign vimeo_id = video_url | split: 'vimeo.com/' | last | split: '?' | first -%}
          <div class="video-section__wrapper" data-video-id="{{ vimeo_id }}" data-video-type="vimeo">
            {%- if section.settings.cover_image != blank -%}
              <img
                src="{{ section.settings.cover_image | image_url: width: 1200 }}"
                alt="{{ section.settings.heading | default: 'Video' | escape }}"
                class="video-section__cover"
                loading="lazy"
                width="1200"
                height="675"
              >
            {%- endif -%}
            <button class="video-section__play" aria-label="Play video">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="white" stroke-width="2" fill="rgba(0,0,0,0.4)"/>
                <polygon points="26,20 26,44 46,32" fill="white"/>
              </svg>
            </button>
          </div>
        {%- endif -%}
      {%- elsif section.settings.shopify_video != blank -%}
        <div class="video-section__wrapper">
          {{ section.settings.shopify_video | video_tag: autoplay: false, controls: true, loop: false, muted: false }}
        </div>
      {%- else -%}
        <div class="video-section__placeholder">
          <svg width="64" height="64" fill="none" stroke="var(--color-text-muted)" stroke-width="1" viewBox="0 0 24 24">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          <p>Add a YouTube, Vimeo, or Shopify-hosted video URL in the Theme Editor</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "See It In Action" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Installation Made Easy" },
    { "type": "textarea", "id": "text", "label": "Description" },
    { "type": "url", "id": "video_url", "label": "YouTube or Vimeo URL" },
    { "type": "video", "id": "shopify_video", "label": "Shopify-hosted video" },
    { "type": "image_picker", "id": "cover_image", "label": "Custom cover image (optional)" }
  ],
  "presets": [{ "name": "Video" }]
}
{% endschema %}
