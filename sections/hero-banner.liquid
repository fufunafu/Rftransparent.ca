<section class="hero" aria-label="Hero banner">
  <!-- Background -->
  <div class="hero__bg">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="
          {{ section.settings.image | image_url: width: 768 }} 768w,
          {{ section.settings.image | image_url: width: 1280 }} 1280w,
          {{ section.settings.image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="{{ section.settings.image_alt | default: shop.name }}"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
      >
    {%- else -%}
      <div style="width:100%;height:100%;background:linear-gradient(135deg, #1C3330 0%, #2E4E49 100%);"></div>
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <!-- Content -->
  <div class="hero__content">
    <div class="hero__text reveal">
      <p class="hero__eyebrow">{{ section.settings.eyebrow | default: "Glass Railing Systems" }}</p>
      <h1 class="hero__heading">
        {{ section.settings.heading | default: "Canada's Premier Glass Railing & Panel Supplier" }}
      </h1>
      <p class="hero__subtext">
        {{ section.settings.subtext | default: "Premium engineered glass railing solutions trusted by contractors and homeowners across Canada. 101+ dealer locations nationwide." }}
      </p>
      <div class="hero__ctas reveal reveal--delay-2">
        <a href="{{ section.settings.cta_primary_url | default: '/collections/all-products' }}" class="btn btn--accent btn--lg">
          {{ section.settings.cta_primary_label | default: "Shop Products" }}
        </a>
        <a href="{{ section.settings.cta_secondary_url | default: '/pages/contact' }}" class="btn btn--outline-white btn--lg">
          {{ section.settings.cta_secondary_label | default: "Get a Quote" }}
        </a>
      </div>
    </div>

    <div class="hero__bottom reveal reveal--delay-3">
      <div class="hero__rating" aria-label="{{ section.settings.review_count | default: '500+' }} customer reviews, rated {{ section.settings.review_score | default: '4.9' }} out of 5">
        <div class="hero__stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            <svg viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {%- endfor -%}
        </div>
        <span class="hero__rating-text">
          <strong>{{ section.settings.review_score | default: "4.9" }}</strong> &mdash; {{ section.settings.review_count | default: "500+" }} verified reviews
        </span>
      </div>
      <div class="hero__scroll" aria-hidden="true">
        <div class="hero__scroll-line"></div>
        <span>Scroll</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Glass Railing Systems" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Canada's Premier Glass Railing & Panel Supplier" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Premium engineered glass railing solutions trusted by contractors and homeowners across Canada. 101+ dealer locations nationwide." },
    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "cta_primary_label", "label": "Button label", "default": "Shop Products" },
    { "type": "url", "id": "cta_primary_url", "label": "Button link" },
    { "type": "header", "content": "Secondary CTA" },
    { "type": "text", "id": "cta_secondary_label", "label": "Button label", "default": "Get a Quote" },
    { "type": "url", "id": "cta_secondary_url", "label": "Button link" },
    { "type": "header", "content": "Reviews Badge" },
    { "type": "text", "id": "review_score", "label": "Review score", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review count label", "default": "500+" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
